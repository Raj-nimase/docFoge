PORT=3001
MONGO_URI=mongodb://127.0.0.1:27017/acadoc
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=

# Cloudinary — image storage (Feature: image upload to cloud)
# Sign up free at https://cloudinary.com and copy values from your dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Render deployment — set this to your Render service URL to enable the
# self-ping keep-alive that prevents the free-tier dyno from spinning down.
# Example: https://your-service-name.onrender.com
# Render sets this automatically — you don't need to add it manually in
# the Render dashboard, but add it here if testing keep-alive locally.
RENDER_EXTERNAL_URL=
